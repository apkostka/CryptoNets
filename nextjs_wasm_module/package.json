{
  "name": "nextjs-15-starter-tailwind",
  "version": "1.0.0",
  "private": false,
  "website": "https://nextjs-15-starter-tailwind-core.vercel.app/",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "yarn fix-imports && cp -R ./node_modules/@privateid/cryptonets-web-sdk-alpha/wasm public/ && cp -R ./node_modules/@privateid/cryptonets-web-sdk-alpha/workers public/",
    "build": "next build",
    "prestart": "yarn fix-imports && cp -R ./node_modules/@privateid/cryptonets-web-sdk-alpha/wasm public/&& cp -R ./node_modules/@privateid/cryptonets-web-sdk-alpha/workers public/",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "fix-imports": "fix-esm-import-path ./node_modules/@privateid/cryptonets-web-sdk-alpha/dist/"
  },
  "dependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@next/env": "^15.3.1",
    "@privateid/cryptonets-web-sdk-alpha": "4.4.15-alpha",
    "@reduxjs/toolkit": "^1.9.0",
    "next": "^15.3.1",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^8.0.5",
    "react-webcam": "^7.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@next/bundle-analyzer": "^15.3.1",
    "@next/eslint-plugin-next": "^15.3.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.14.1",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "^9.25.0",
    "eslint-config-next": "15.3.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "fix-esm-import-path": "^1.10.1",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}